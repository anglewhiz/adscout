# Data-provider API credentials (SpyFu: Account Settings > API Usage on spyfu.com)
# Only needed for "Live" mode. Leave unset to run Demo/Mock modes.
#
# EASIEST: paste the pre-generated Base64 shown on the API Usage page. This is
# base64("API_ID:SECRET_KEY") and avoids mis-copying the two parts separately.
# SPYFU_BASIC_AUTH=paste_the_base64_string_here
#
# OR provide the two parts and we'll encode them:
SPYFU_API_ID=00000000-0000-0000-0000-000000000000
SPYFU_SECRET_KEY=your_secret_key

# Anthropic API key (for AdSherlock's reasoning loop). Needed for Mock and Live modes.
ANTHROPIC_API_KEY=sk-ant-...

# Meta (Facebook/Instagram) Ad Library, via an Apify scraper actor.
# Enables the search_facebook_ads / get_advertiser_facebook_ads tools in Live
# mode. Get a token at apify.com (Console > Settings > Integrations). Optional —
# without it, only Google Search (SpyFu) data is used.
APIFY_TOKEN=apify_api_...
# Optional: override the scraper actor (default: apify/facebook-ads-scraper)
# APIFY_FB_ACTOR=apify/facebook-ads-scraper

# Optional overrides
ANALYST_MODEL=claude-sonnet-5
SPYFU_COUNTRY=US
