{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "server.py": {
      "maxDuration": 300,
      "includeFiles": "adscout/**"
    },
    "api/ask.py": {
      "maxDuration": 60,
      "includeFiles": "adscout/**"
    },
    "api/status.py": {
      "maxDuration": 10,
      "includeFiles": "adscout/**"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ]
}
